      "source": [
        "# Create a 100x100 image with random noise\n",
        "# This simulates the background noise in a real fluorescence microscopy image\n",
        "#np.ogrid[0:100, 0:100]\n",
        "\n",
        "#Creates two coordinate grids — one for rows (y) and one for columns (x).\n",
        "#Think of it as laying a ruler across and down your image so every pixel knows its position.\n",
        "image_noise = np.random.normal(loc=0.2, scale=0.05, size=(100, 100))\n",
        "\n",
        "# loc=0.2 — the average value of the noise is 0.2 (dim gray background)\n",
        "# scale=0.05 — how much the values vary around that average\n",
        "# size=(100,100) — the dimensions of the image\n",
        "\n",
        "# Add a bright circular signal in the middle\n",
        "# Creates two coordinate grids — one for rows (y) and one for columns (x).\n",
        "#Think of it as laying a ruler across and down your image so every pixel knows its position.\n",
        "y, x = np.ogrid[0:100, 0:100]\n",
        "center_y, center_x = 50, 50\n",
        "radius = 15\n",
        "circle = (x - center_x)**2 + (y - center_y)**2 <= radius**2\n",
        "#Every pixel inside the circle gets its intensity set to 0.8 (bright).\n",
        "#This is how you apply a mask to an image — a concept you will use constantly in segmentation later.\n",
        "image_noise[circle] = 0.8\n",
        "\n",
        "# Display it\n",
        "plt.figure(figsize=(6, 6))\n",
        "plt.imshow(image_noise, cmap='gray')\n",
        "plt.colorbar()\n",
        "plt.title('Simulated fluorescence image')\n",
        "plt.show()"
      ],
